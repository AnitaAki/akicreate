    {
      "cell_type": "code",
      "source": [
        "from sklearn.neighbors import KNeighborsClassifier, NearestCentroid\n",
        "from sklearn.svm import SVC                                # RBF = distance in kernel space\n",
        "from sklearn.discriminant_analysis import LinearDiscriminantAnalysis  # Mahalanobis distance\n",
        "\n",
        "print(\"✅ All libraries imported successfully!\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
