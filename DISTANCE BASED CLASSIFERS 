            "✅ Train set : 1347 samples\n",
            "   Test  set : 450 samples\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "classifiers = {\n",
        "    \"KNN (k=5, Euclidean)\":    KNeighborsClassifier(n_neighbors=5, metric=\"euclidean\"),\n",
        "    \"KNN (k=3, Manhattan)\":    KNeighborsClassifier(n_neighbors=3, metric=\"manhattan\"),\n",
        "    \"Nearest Centroid\":        NearestCentroid(metric=\"euclidean\"),\n",
        "    \"SVM (RBF kernel)\":        SVC(kernel=\"rbf\",    C=1.0, gamma=\"scale\"),\n",
        "    \"SVM (Linear kernel)\":     SVC(kernel=\"linear\", C=1.0),\n",
        "    \"LDA (Mahalanobis dist.)\": LinearDiscriminantAnalysis(solver=\"svd\"),\n",
        "}\n",
        "\n",
        "print(\"✅ Classifiers defined:\")\n",
