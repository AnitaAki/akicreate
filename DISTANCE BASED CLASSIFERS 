    {
      "cell_type": "code",
      "source": [
        "digits = load_digits()\n",
        "\n",
        "X_full = digits.data    # 1797 samples × 64 pixel features\n",
        "y      = digits.target  # Labels: digits 0 to 9\n",
        "\n",
        "# Reduce to 10 features using PCA (still satisfies \">5 variables\")\n",
        "pca = PCA(n_components=10, random_state=42)\n",
        "X   = pca.fit_transform(X_full)\n",
        "\n",
        "print(\"📊 Dataset Summary\")\n",
        "print(f\"   Total rows    : {X.shape[0]}\")\n",
        "print(f\"   Features used : {X.shape[1]} (PCA components)\")\n",
        "print(f\"   Classes       : {sorted(np.unique(y).tolist())}  → digits 0–9\")\n",
        "print(f\"   Variance kept : {pca.explained_variance_ratio_.sum():.1%}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "xegh5_196Ln7",
        "outputId": "7797bb5e-6c9d-475a-919c-0a6f012f2de3"
